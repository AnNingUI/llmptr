  "stream": false,
  "compare_go": true,
  "input": {
    "model": "gpt-client",
    "input": [
      {
        "type": "function_call",
        "call_id": "call.with space:1",
        "name": "mcp__node_repl__js",
        "arguments": "{\"code\":\"nodeRepl.write('ok')\"}"
      },
      {
        "type": "message",
        "role": "assistant",
