      },
      {
        "type": "namespace",
        "name": "mcp__node_repl",
        "tools": [
          {
            "type": "function",
            "name": "js",
            "parameters": {
              "type": "object"
            }
          }
        ]
      },
      {
        "type": "web_search",
        "name": "web_search",
        "max_uses": 2,
        "filters": {
          "allowed_domains": ["example.com"]
        }
      },
      {
        "type": "file_search",
        "name": "files"
      }
    ],
    "tool_choice": {
      "type": "function",
      "function": {
        "name": "js"
      }
    }
  }
