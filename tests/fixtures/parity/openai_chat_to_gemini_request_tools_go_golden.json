{
  "name": "openai_chat_to_gemini_request_tools_go_golden",
  "kind": "request",
  "from": "openai",
  "to": "gemini",
  "model": "gemini-test",
  "compare_go": true,
  "input": {
    "messages": [
      {
        "role": "user",
        "content": "Weather?"
      },
      {
        "role": "assistant",
        "content": "I'll call the tool.",
        "tool_calls": [
          {
            "id": "call.weather",
            "type": "function",
            "function": {
              "name": "get weather!",
              "arguments": "{\"city\":\"Tokyo\",\"unit\":\"c\"}"
            },
            "extra_content": {
              "google": {
                "thought_signature": "skip_thought_signature_validator"
              }
            }
          }
        ]
      },
      {
        "role": "tool",
        "tool_call_id": "call.weather",
        "content": {
          "ok": true,
          "temp": 21
        }
      },
      {
        "role": "user",
        "content": "Summarize it."
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get weather!",
          "description": "Get weather",
          "parameters": {
            "type": "object",
            "properties": {
              "city": {
                "type": "string"
              },
              "unit": {
                "type": "string",
                "enum": ["c", "f"]
              }
            },
            "required": ["city"]
          },
          "strict": true
        }
      },
      {
        "google_search": {}
      },
      {
        "code_execution": {}
      },
      {
        "url_context": {}
      }
    ]
  }
}
